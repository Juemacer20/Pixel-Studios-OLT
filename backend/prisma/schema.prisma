generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OLTStatus {
  ONLINE
  OFFLINE
  DEGRADED
  MAINTENANCE
}

enum ONTStatus {
  ONLINE
  OFFLINE
  LOS
  DYING_GASP
  PENDING
  DEACTIVATED
}

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum AlertType {
  LOS
  DYING_GASP
  HIGH_SIGNAL
  LOW_SIGNAL
  CPU_HIGH
  TEMP_HIGH
  PORT_DOWN
  ONT_OFFLINE
  CUSTOM
}

enum Protocol {
  GPON
  EPON
  XGSPON
}

enum WANMode {
  DHCP
  STATIC
  PPPOE
}

model OLT {
  id                    String    @id @default(uuid())
  name                  String    @unique
  brand                 String
  model                 String
  ip                    String    @unique
  community             String    @default("public")
  port                  Int       @default(161)
  location              String?
  credentials_encrypted String?
  status                OLTStatus @default(OFFLINE)
  uptime                BigInt?
  cpu_usage             Float?
  temperature           Float?
  tcp_port              Int?
  udp_port              Int?
  hw_version            String?
  sw_version            String?
  snmp_read             String?
  snmp_write            String?
  telnet_user           String?
  telnet_pass           String?
  pon_type              String?   @default("GPON")
  iptv_enabled          Boolean   @default(false)
  latitude              Float?
  longitude             Float?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  ponPorts   PONPort[]
  onts       ONT[]
  alerts     Alert[]
  oltHistory OLTHistory[]

  @@map("olts")
}

model OLTHistory {
  olt_id      String
  timestamp   DateTime @default(now())
  cpu_usage   Float?
  temperature Float?
  olt         OLT      @relation(fields: [olt_id], references: [id], onDelete: Cascade)

  @@id([olt_id, timestamp])
  @@map("olt_history")
}

model PONPort {
  id          String @id @default(uuid())
  olt_id      String
  port_number Int
  capacity    Int    @default(128)
  used        Int    @default(0)
  status      String @default("active")

  olt  OLT   @relation(fields: [olt_id], references: [id], onDelete: Cascade)
  onts ONT[]

  @@unique([olt_id, port_number])
  @@map("pon_ports")
}

model ONT {
  id                   String    @id @default(uuid())
  olt_id               String
  pon_port_id          String?
  serial_number        String    @unique
  mac                  String?
  description          String?
  status               ONTStatus @default(OFFLINE)
  rx_power             Float?
  tx_power             Float?
  olt_rx_power         Float?
  distance             Int?
  temperature          Float?
  voltage              Float?
  bias_current         Float?
  model                String?
  firmware             String?
  vlan                 Int?
  ip_address           String?
  uptime               BigInt?
  last_seen            DateTime?
  provisioned_at       DateTime?
  latitude             Float?
  longitude            Float?
  nap_box_id           String?
  speed_profile_id     String?
  protocol             Protocol  @default(GPON)
  external_id          String?
  contact              String?
  zone                 String?
  odb                  String?
  board                Int?
  port                 Int?
  onu_id               Int?
  channel              Int?
  mgmt_ip              String?
  sw_version           String?
  wan_mode             String?
  pppoe_user           String?
  configuration_method String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  olt           OLT             @relation(fields: [olt_id], references: [id])
  ponPort       PONPort?        @relation(fields: [pon_port_id], references: [id])
  napBox        NAPBox?         @relation(fields: [nap_box_id], references: [id])
  speedProfile  SpeedProfile?   @relation(fields: [speed_profile_id], references: [id])
  client        Client?
  alerts        Alert[]
  signalHistory SignalHistory[]
  dhcpLeases    DHCPLease[]
  tr069Device   TR069Device?

  @@map("onts")
}

model Client {
  id              String   @id @default(uuid())
  ont_id          String   @unique
  name            String
  address         String?
  phone           String?
  email           String?
  service_plan    String?
  contract_number String?  @unique
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  ont          ONT           @relation(fields: [ont_id], references: [id])
  tr069Devices TR069Device[]

  @@map("clients")
}

model Alert {
  id           String        @id @default(uuid())
  olt_id       String?
  ont_id       String?
  type         AlertType
  severity     AlertSeverity
  message      String
  acknowledged Boolean       @default(false)
  resolved     Boolean       @default(false)
  created_at   DateTime      @default(now())
  resolved_at  DateTime?
  ack_at       DateTime?
  ack_by       String?

  olt OLT? @relation(fields: [olt_id], references: [id])
  ont ONT? @relation(fields: [ont_id], references: [id])

  @@map("alerts")
}

model SignalHistory {
  ont_id    String
  rx_power  Float?
  tx_power  Float?
  timestamp DateTime @default(now())

  ont ONT @relation(fields: [ont_id], references: [id], onDelete: Cascade)

  @@id([ont_id, timestamp])
  @@map("signal_history")
}

model TR069Device {
  id                     String    @id @default(uuid())
  serial_number          String    @unique
  oui                    String?
  product_class          String?
  manufacturer           String?
  software_version       String?
  hardware_version       String?
  ip_address             String?
  last_inform            DateTime?
  connection_request_url String?
  ont_id                 String?   @unique
  client_id              String?
  parameters             Json?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  ont    ONT?    @relation(fields: [ont_id], references: [id])
  client Client? @relation(fields: [client_id], references: [id])

  @@map("tr069_devices")
}

model ServiceProfile {
  id             String   @id @default(uuid())
  name           String   @unique
  data_vlan      Int?
  voip_vlan      Int?
  iptv_vlan      Int?
  speed_down     Int?
  speed_up       Int?
  wan_mode       WANMode  @default(DHCP)
  sip_server     String?
  multicast_vlan Int?
  created_at     DateTime @default(now())

  ztpProfiles ZTPProfile[]

  @@map("service_profiles")
}

model ZTPProfile {
  id                 String   @id @default(uuid())
  name               String   @unique
  service_profile_id String?
  description        String?
  created_at         DateTime @default(now())

  serviceProfile ServiceProfile? @relation(fields: [service_profile_id], references: [id])

  @@map("ztp_profiles")
}

model NotificationConfig {
  id           String        @id @default(uuid())
  channel      String
  destination  String
  events       Json
  severity_min AlertSeverity @default(HIGH)
  schedule     Json?
  enabled      Boolean       @default(true)
  created_at   DateTime      @default(now())

  @@map("notification_configs")
}

model SpeedProfile {
  id            String   @id @default(uuid())
  name          String
  direction     String? // DOWNLOAD / UPLOAD / BOTH
  speedKbps     Int?
  download_mbps Int      @default(0)
  upload_mbps   Int      @default(0)
  burst_down    Int?
  burst_up      Int?
  type          String? // INTERNET / IPTV / MGMT
  isDefault     Boolean  @default(false)
  forPonType    String? // GPON / EPON / ANY
  ont_count     Int?
  created_at    DateTime @default(now())

  onts ONT[]

  @@unique([name, direction])
  @@map("speed_profiles")
}

model NAPBox {
  id          String   @id @default(uuid())
  name        String
  latitude    Float?
  longitude   Float?
  address     String?
  ports_total Int      @default(16)
  ports_used  Int      @default(0)
  zone        String?
  odb_port    Int?
  created_at  DateTime @default(now())

  onts ONT[]

  @@map("nap_boxes")
}

model DHCPLease {
  id         String    @id @default(uuid())
  ont_id     String
  ip         String
  mac        String
  hostname   String?
  expires_at DateTime?
  created_at DateTime  @default(now())

  ont ONT @relation(fields: [ont_id], references: [id], onDelete: Cascade)

  @@map("dhcp_leases")
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  action      String
  action_type String? // ONT_ACTION, OLT_ACTION, SYSTEM, AUTH, EXPORT, IMPORT
  target      String?
  target_type String? // ONT, OLT, ZONE, ODB, PRESET, USER
  details     Json?
  ip_address  String?
  created_at  DateTime @default(now())

  @@map("audit_logs")
}

model NetStatusHistory {
  timestamp DateTime @id @default(now())
  online    Int
  powerfail Int      @default(0)
  los       Int      @default(0)
  na        Int      @default(0)
  offline   Int?

  @@map("net_status_history")
}

model AutoActionPreset {
  id                String   @id @default(uuid())
  name              String
  olts              String? // JSON array de OLT IDs o "all"
  boards            String? // JSON array de boards o null
  ports             String? // JSON array de ports o null
  ponType           String? // GPON / EPON
  snPattern         String? // Regex para SN
  onuTypeId         String?
  fallbackOnuTypeId String?
  isDefault         Boolean  @default(false)
  mode              String? // Bridge / Router
  svlanId           Int?
  cvlanId           Int?
  tagTransform      String? // default / translate / transparent
  downloadSpeed     Int? // Kbps
  uploadSpeed       Int? // Kbps
  zoneId            String?
  odbId             String?
  webUser           String?
  webPassword       String?
  description       String?
  isActive          Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("auto_action_presets")
}

model AuthorizationPreset {
  id                String   @id @default(uuid())
  name              String
  description       String?
  oltId             String?
  board             Int?
  port              Int?
  ponType           String?
  snPattern         String?
  onuTypeId         String?
  fallbackOnuTypeId String?
  mode              String? // Bridge / Router
  svlanId           Int?
  cvlanId           Int?
  tagTransform      String?
  downloadSpeedId   String?
  uploadSpeedId     String?
  zoneId            String?
  odbId             String?
  webUser           String?
  webPassword       String?
  isActive          Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("authorization_presets")
}

model SignalThresholdConfig {
  id                  String   @id @default(uuid())
  variationThreshold  Float?   @default(3.0)
  largeVariationDelta Float?   @default(5.0)
  multiOnuThreshold   Int?     @default(3)
  trendWindowHours    Int?     @default(24)
  trendMinEvents      Int?     @default(5)
  updated_at          DateTime @updatedAt

  @@map("signal_threshold_config")
}

model ApiKey {
  id               String    @id @default(uuid())
  key              String    @unique
  name             String
  type             String? // full / read-only / billing
  restrictionGroup String?
  allowedIPs       String? // JSON array o CSV
  isActive         Boolean   @default(true)
  lastUsedAt       DateTime?
  created_at       DateTime  @default(now())
  expires_at       DateTime?

  @@map("api_keys")
}

model OltSubscription {
  id         String    @id @default(uuid())
  olt_id     String    @unique
  status     String    @default("active") // active, expired, trial
  endDate    DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@map("olt_subscriptions")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password_hash   String
  name            String?
  group           String   @default("noc") // admin / noc
  status          String   @default("active") // active / inactive
  twofa_enabled   Boolean  @default(false)
  twofa_secret    String?
  remember_token  String?
  ip_access       String? // CSV de IPs permitidas o null = todas
  installer_limit Int? // días límite para installer (default 3)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("users")
}

model OnuType {
  id                  String   @id @default(uuid())
  name                String   @unique
  ponType             String? // GPON / EPON / XGSPON
  channels            Int?
  ethernetPorts       Int?
  wifiBands           String? // 2.4G, 5G, 2.4G+5G
  voipPorts           Int?
  hasCATV             Boolean  @default(false)
  allowCustomProfiles Boolean  @default(false)
  capability          String? // HGU, SFU, MDU, etc.
  created_at          DateTime @default(now())

  @@map("onu_types")
}

model VpnTunnel {
  id         String   @id @default(uuid())
  name       String
  oltIds     String // JSON array OLT IDs
  status     String   @default("active")
  subnet     String?
  connected  String?
  created_at DateTime @default(now())

  @@map("vpn_tunnels")
}

model Tr069Profile {
  id         String   @id @default(uuid())
  name       String
  acsUrl     String?
  status     String   @default("active")
  oltIds     String? // JSON array
  created_at DateTime @default(now())

  @@map("tr069_profiles")
}
