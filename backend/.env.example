# Server
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pixel_studios_olt

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AES Encryption for credentials
AES_KEY=your-32-char-aes-256-key-here!!

# SNMP
SNMP_TIMEOUT=5000
SNMP_RETRIES=3
SNMP_VERSION=2c

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@pixel-studios.com
SMTP_PASS=your-smtp-password

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# Polling intervals (ms)
POLL_OLT_INTERVAL=60000
POLL_SIGNAL_INTERVAL=300000
ALERT_ENGINE_INTERVAL=15000

# Enriquecimiento de info de ONTs (job de fondo, lee detalle por ONT de la OLT)
ENRICH_INTERVAL_MS=60000
ENRICH_BATCH_SIZE=50
ENRICH_STALE_DAYS=7

# Logs
LOG_LEVEL=info
LOG_DIR=./logs
